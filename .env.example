# Required at BUILD time (Netlify / CI) to pull pkf data from the
# private se-regional-data repo's GitHub Releases. Not needed for `npm run dev`.

# "<owner>/<repo>" of the data repo.
DATA_REPO=larsgson/se-regional-data

# Personal access token or Actions token with read access to DATA_REPO.
# For Netlify: set in Site settings → Environment variables (encrypted).
GITHUB_TOKEN=

# Optional: pin to a specific release tag (e.g. "data-2026.04.22").
# Defaults to "latest" when unset.
# DATA_RELEASE_TAG=latest

# Optional: set to "1" to skip the prebuild data fetch entirely.
# Useful locally when you already have data/pkf/ populated.
# SKIP_DATA_FETCH=1
