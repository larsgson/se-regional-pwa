# Build-time config for scripts/fetch-data.mjs. All variables are optional —
# the data repo is public, so a clean build works with zero env vars set.

# Override the data repo. Defaults to "larsgson/se-regional-data".
# DATA_REPO=larsgson/se-regional-data

# Pin to a specific release tag (e.g. "data-2026.04.23") for reproducible
# builds. Defaults to "latest", resolved via GitHub's stable alias.
# DATA_RELEASE_TAG=latest

# Optional GitHub token — only useful for rate-limit headroom on busy CI
# runners. Anonymous reads work fine.
# GITHUB_TOKEN=

# Set to "1" to skip the prebuild data fetch entirely.
# Useful locally when you already have data/pkf/ populated.
# SKIP_DATA_FETCH=1
